# ============================================================
# CRM SEGUROS - Variables de Entorno
# Copiá este archivo como .env.local y completá los valores
# ============================================================

# URL de tu Supabase local (el servidor Ubuntu)
NEXT_PUBLIC_SUPABASE_URL=http://192.168.0.2:8001

# Clave pública (anon key) — la encontrás en Supabase Studio
# Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Clave privada (service role) — NUNCA la expongas en el frontend
# Solo para operaciones server-side
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# API key de Anthropic — para features de IA (importador de cartera, etc.)
# Conseguila en https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Clave de encriptación — para encriptar contraseñas SMTP y datos sensibles
# Generala con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Secret compartido para los endpoints /api/cron/* (systemd → curl -H "Authorization: Bearer $CRON_SECRET" ...)
# Generar con: openssl rand -hex 32
CRON_SECRET=

# Clave HMAC para firmar tokens de acceso a archivos vía /api/storage/[...path]?token=...
# Generar con: openssl rand -hex 32
STORAGE_SIGNING_KEY=

# URL pública del Portal del Cliente (ej: https://clientes.miproductora.com.ar)
# Desde acá se construyen los links que el productor envía a cada cliente.
# La configura el instalador al montar el CRM en cada cliente.
URL_PORTAL_CLIENTE=
