# ────────────────────────────────────────────────────────────────
# CRM Seguros — variables de entorno
# Copiar a .env.local y completar con los valores reales.
# ────────────────────────────────────────────────────────────────

# Supabase self-hosted
NEXT_PUBLIC_SUPABASE_URL=http://192.168.0.2:8001
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Encriptación (64 chars hex, AES-256-GCM). Usada para SMTP password y Anthropic API key.
# Generá una con: openssl rand -hex 32
ENCRYPTION_KEY=

# Portal del cliente
URL_PORTAL_CLIENTE=

# Secret para los endpoints /api/cron/* (llamados por systemd)
CRON_SECRET=

# ────────────────────────────────────────────────────────────────
# Anthropic / Importador IA v2
# ────────────────────────────────────────────────────────────────
# La API key de Claude NO se configura desde .env. El PAS la carga desde
# la pantalla /crm/configuracion/agente-ia y queda encriptada en la tabla
# `configuracion`. Solo usá esta variable si el instalador pre-carga una
# key por defecto durante el deploy inicial.
ANTHROPIC_API_KEY_DEFAULT=

# ────────────────────────────────────────────────────────────────
# Sentry (telemetría de errores hacia el equipo de FidCore)
# ────────────────────────────────────────────────────────────────
# DSN del proyecto de Sentry. Si está vacío, Sentry queda deshabilitado
# y todos los `Sentry.init()` son no-op (la persistencia local en
# `errores_sistema` sigue funcionando igual). Mismo valor en server y client.
NEXT_PUBLIC_SENTRY_DSN=

# Identidad de esta instalación. Si está vacío, se genera automáticamente
# y se persiste en `storage/.instalacion-id`. El instalador del producto
# puede pre-fijarlo acá para correlacionar el ID del cliente en Sentry.
INSTALACION_ID=

# Versión visible del CRM (release de Sentry). Se usa para etiquetar errores
# por versión. Si está vacío, Sentry omite el `release` del evento.
NEXT_PUBLIC_APP_VERSION=

# Solo en builds del equipo de FidCore (no en instalaciones de clientes).
# Si está presente, el plugin de Sentry sube source maps al hacer
# `npm run build`. Sin él, el build sigue funcionando igual.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
