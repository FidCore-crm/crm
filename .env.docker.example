# ============================================================================
# .env.docker.example — copialo como .env.docker durante la instalación
#
# Lo lee `env_file` de docker-compose.yml. Es el equivalente del .env.local
# pero pensado para Docker (no se commitea, va con secrets reales).
#
# Generar secrets nuevos para cada instalación:
#   ENCRYPTION_KEY:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   CRON_SECRET:     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================================

# --- Supabase ---
# Dos URLs:
#  - NEXT_PUBLIC_SUPABASE_URL (browser): URL pública. El bundle del cliente
#    la inlinea en `next build`. Patrón típico path-based para evitar
#    subdominios anidados que requieran ACM en CF:
#      https://<cliente>.fidcore.com.ar/supabase
#    El rewrite en `next.config.js` redirige `/supabase/*` al kong de Docker.
#  - SUPABASE_INTERNAL_URL (server): el server Node.js le habla DIRECTO al
#    kong por la network Docker. Saltea internet y el rewrite — más rápido.
#    Default si está vacío: cae a NEXT_PUBLIC_SUPABASE_URL (compat dev).
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_INTERNAL_URL=http://supabase-kong:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Postgres directo (para scripts de backup/restore/migraciones) ---
# Los scripts dentro del container se conectan por TCP al alias `supabase-db`
# de la network supabase_default.
POSTGRES_HOST=supabase-db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_DB=postgres
POSTGRES_PASSWORD=

# --- Encriptación + cron auth ---
ENCRYPTION_KEY=
CRON_SECRET=

# --- IA (Anthropic) ---
# Fallback. La key real la carga el PAS desde la UI (queda encriptada en DB).
ANTHROPIC_API_KEY=

# --- URLs públicas ---
# Las 3 URLs son fallbacks. El PAS puede sobreescribirlas desde
# `/crm/configuracion/perfil` y queda guardado en `configuracion`. Usar HTTPS
# en producción detrás de Cloudflare Tunnel.
#
# Modelo single-hostname (recomendado, free SSL en CF plan free):
#   URL_CRM_PUBLICA=https://<cliente>.fidcore.com.ar
#   URL_PORTAL_CLIENTE=https://<cliente>.fidcore.com.ar
#   URL_FORMULARIO_PUBLICO=https://<cliente>.fidcore.com.ar/denuncia
URL_CRM_PUBLICA=
URL_PORTAL_CLIENTE=
URL_FORMULARIO_PUBLICO=

# --- Cloudflare Tunnel ---
# Token único del tunnel para esta instalación (obtenido al crear el tunnel
# en el dashboard de Cloudflare Zero Trust). El token incluye el endpoint
# del tunnel + las credenciales para conectarse. NO se rota frecuentemente.
TUNNEL_TOKEN=

# --- Telemetría Sentry (opcional pero recomendado) ---
NEXT_PUBLIC_SENTRY_DSN=

# --- Identificador visual del stack (sidebar) ---
# Productivo: dejar vacío. Dev/staging: setear "DOCKER" / "STAGING" / etc.
# El badge naranja aparece junto a la versión del CRM en el sidebar.
NEXT_PUBLIC_STACK_LABEL=

# --- Feature flag: incluir pre-releases en verificación de updates ---
# SOLO para servers de dev/staging del equipo FidCore. Si está en `true`, el
# server consulta /releases de GitHub (todos) en vez de /releases/latest, y
# detecta también los releases marcados como pre-release. Sirve para validar
# el flujo de actualización antes de promover una versión a "Latest".
#
# En instalaciones de clientes esta variable debe quedar VACÍA o ausente —
# de lo contrario el cliente podría recibir versiones no probadas.
# FIDCORE_INCLUIR_PRERELEASES=true
